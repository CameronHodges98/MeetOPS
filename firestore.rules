rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global performance data — all authenticated users can read and write
    match /performanceDays/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Global cycle time data — same rules, with nested subcollection
    match /ctDays/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      match /employees/{emp} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // Admins collection — readable by all auth users, writable only via Firebase console
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
