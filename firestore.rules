rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: true if the requesting user has a document in the admins collection.
    // Document existence (not content) determines admin status — same check used
    // by checkAdminRole() on the client side.
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Global performance data — any authenticated user can read and write.
    // Any manager can upload CSV data; all managers see the same shared dataset.
    // Role enforcement (admin vs manager view) is handled client-side.
    match /performanceDays/{date} {
      allow read, write: if request.auth != null;
    }

    // Global cycle time data — same open read/write for all authenticated users.
    match /ctDays/{date} {
      allow read, write: if request.auth != null;
      match /employees/{emp} {
        allow read, write: if request.auth != null;
      }
    }

    // Admins collection — readable by all auth users so the client can perform
    // the role check; writable only via Firebase console (never from the app).
    match /admins/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Invite tokens — public read so unauthenticated CTs can validate their link
    // before creating an account. UUID tokens are unguessable so public read is safe.
    // Create requires auth (managers only). Update is public so the CT can mark the
    // token used immediately after account creation (before their session fully loads).
    match /invites/{token} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;
    }

    // Certified trainers — any auth user can read; CT can only create their own doc;
    // any auth user can delete (manager revoke flow).
    match /certifiedTrainers/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null;
    }

    // Coaching assignments — any authenticated user can read/write.
    // Scoping is enforced client-side (managerId / ctId fields).
    match /coachings/{id} {
      allow read, write: if request.auth != null;
    }

    // Revoked users — any authenticated user can read/write.
    // Written by manager during revoke; read by initApp() gate check.
    match /revokedUsers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Role assignments (ops_manager / general_manager) — any auth user can read
    // so role resolution works client-side; write open to auth users (client enforces
    // that only admins and GMs can assign roles).
    match /roles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // User registry — written by each user on login to enable the GM role management UI.
    // Users can only write their own doc; any auth user can read the full list.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
